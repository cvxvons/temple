ote{color:var(--muted); font-size:13px}\n.form-success{display:none; align-items:center; gap:14px; padding:20px 22px; border:1px solid color-mix(in srgb,var(--accent) 40%,transparent); border-radius:14px; background:color-mix(in srgb,var(--accent) 8%,transparent); margin-top:10px}\n.form-success.show{display:flex}\n.form-success .dot{width:9px; height:9px; border-radius:50%; background:var(--accent); flex:none; box-shadow:0 0 0 4px color-mix(in srgb,var(--accent) 25%,transparent)}\n\n/* ============================================================\n   FOOTER  — light \"dawn\" footer with grayscale aurora horizon\n   ============================================================ */\n.footer{\n  --fbg:#efece6; --fink:#16130f; --fmuted:#8c8a84; --fline:rgba(22,19,15,.16);\n  position:relative; overflow:hidden; background:var(--fbg); color:var(--fink);\n  padding:clamp(40px,7vh,84px) 0 0;\n}\n/* aurora transition: dark page → light footer with a soft wavy horizon (blur-free) */\n.footer-sky{position:relative; height:clamp(320px,44vh,540px); overflow:hidden;\n  background:linear-gradient(to bottom, var(--bg) 0%, var(--bg) 30%, color-mix(in srgb,var(--bg) 55%,#efece6) 64%, #efece6 100%);}\n.footer-wave{position:absolute; inset:0; width:100%; height:100%; display:block; z-index:2}\n:root[data-mood=\"parchment\"] .footer-sky{background:linear-gradient(to bottom,var(--bg),#efece6)}\n\n/* prismatic ray glow blooming along the horizon */\n.footer-glow{position:absolute; left:50%; top:60%; width:132%; height:56%;\n  transform:translate(-50%,-50%); z-index:1; pointer-events:none;\n  filter:blur(58px) saturate(1.4); opacity:.7; mix-blend-mode:screen;\n  background:\n    radial-gradient(36% 130% at 15% 52%, rgba(170,96,214,.60), transparent 68%),\n    radial-gradient(30% 120% at 27% 57%, rgba(226,150,68,.58), transparent 68%),\n    radial-gradient(26% 120% at 39% 49%, rgba(118,198,150,.44), transparent 70%),\n    radial-gradient(26% 120% at 61% 49%, rgba(118,198,150,.44), transparent 70%),\n    radial-gradient(30% 120% at 73% 57%, rgba(226,150,68,.58), transparent 68%),\n    radial-gradient(36% 130% at 85% 52%, rgba(170,96,214,.60), transparent 68%);}\n\n/* footer wave — a slow flowing tide that breathes; the ray pulses with it */\n.footer-wave .wmove{transform-box:view-box}\n.footer-wave .wmove path{transform-box:view-box; transform-origin:50% 100%}\n@media (prefers-reduced-motion: no-preference){\n  /* horizontal drift + a vertical swell on two un-synced periods → organic, never-quite-repeating */\n  .footer-wave .wmove-back{animation:waveDrift 23s linear infinite}\n  .footer-wave .wmove-front{animation:waveDrift 16s linear infinite}\n  .footer-wave .wmove-back path{animation:waveSwell 8.5s ease-in-out infinite alternate}\n  .footer-wave .wmove-front path{animation:waveSwellFront 6s ease-in-out infinite alternate}\n  /* glow breathes on the SAME 6s beat as the front wave so the ray pulses with the crest */\n  .footer-glow{animation:glowBreathe 6s ease-in-out infinite alternate}\n}\n@keyframes waveDrift{from{transform:translateX(0)}to{transform:translateX(-720px)}}\n@keyframes waveSwell{\n  0%{transform:translateY(3px) scaleY(.975)}\n  100%{transform:translateY(-11px) scaleY(1.045)}}\n@keyframes waveSwellFront{\n  0%{transform:translateY(4px) scaleY(.97)}\n  100%{transform:translateY(-15px) scaleY(1.06)}}\n@keyframes glowBreathe{\n  0%{opacity:.4; transform:translate(-50%,-46%) scale(.96)}\n  100%{opacity:.86; transform:translate(-50%,-54%) scale(1.09)}}\n\n.footer-grid{position:relative; z-index:2; display:grid; grid-template-columns:1.5fr 3fr; gap:clamp(36px,6vw,90px); align-items:start}\n.footer-brand{display:flex; flex-direction:column; gap:18px}\n.footer-logo{display:flex; align-items:center; gap:13px}\n.footer-logo .footer-lockup{height:26px; width:auto; color:var(--fink); flex:none}\n.footer-logo .fmark{height:26px; width:auto; color:var(--fink); flex:none}\n.footer-logo .logo{height:26px; color:var(--fink)}\n.footer-brand p{color:var(-